{
  "redirects": [
    {
      "source": "/teltguide",
      "destination": "/hvor-stort-partytelt",
      "permanent": true
    },
    {
      "source": "/priser",
      "destination": "/kalkulator",
      "permanent": true
    },
    {
      "source": "/teltutleie",
      "destination": "/partytelt",
      "permanent": true
    },
    {
      "source": "/partytelt-utleie",
      "destination": "/partytelt",
      "permanent": true
    },
    {
      "source": "/leie-bord-og-stoler",
      "destination": "/bord-og-stoler",
      "permanent": true
    },
    {
      "source": "/bord-og-stoler-sandefjord",
      "destination": "/bord-og-stoler",
      "permanent": true
    },
    {
      "source": "/konfirmasjonstelt",
      "destination": "/partytelt-konfirmasjon",
      "permanent": true
    },
    {
      "source": "/bryllupstelt",
      "destination": "/partytelt-bryllup",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Expires",
          "value": "Thu, 31 Dec 2037 23:55:55 GMT"
        }
      ]
    },
    {
      "source": "/logo.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Expires",
          "value": "Thu, 31 Dec 2037 23:55:55 GMT"
        }
      ]
    },
    {
      "source": "/leievilkar_holsvik_co_full.pdf",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
